# My Little Books — Apache Config

# Enable rewrite
Options -Indexes
Options +FollowSymLinks

# PHP settings
php_value session.cookie_httponly 1
php_value session.use_strict_mode 1

# Cache static assets
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpeg "access plus 1 month"
  ExpiresByType image/png  "access plus 1 month"
  ExpiresByType image/webp "access plus 1 month"
  ExpiresByType text/css   "access plus 1 week"
  ExpiresByType application/javascript "access plus 1 week"
</IfModule>

# Security headers
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
</IfModule>

# Protect uploads — no PHP execution in upload folders
<FilesMatch "\.(php|php3|php4|php5|phtml|pl|py|jsp|asp|htm|html|shtml|sh|cgi)$">
  <If "%{REQUEST_URI} =~ m#/assets/uploads/#">
    Deny from all
  </If>
</FilesMatch>

# Protect sensitive config files
<Files "ai_config.php">
  Order Allow,Deny
  Deny from all
</Files>

# Default to index.html
DirectoryIndex index.html login.html
